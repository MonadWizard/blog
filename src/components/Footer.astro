---
const year = new Date().getFullYear();

const links = [
  { href: 'https://github.com/MonadWizard', label: 'GitHub' },
  { href: 'https://www.linkedin.com/in/rakib-hasan-90518b140/', label: 'LinkedIn' },
  { href: 'mailto:monad.wizard.r@gmail.com', label: 'Email' },
];
---

<footer class="border-t border-gray-200 dark:border-gray-800 mt-20">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="text-center sm:text-left">
        <div class="flex items-center gap-2 justify-center sm:justify-start">
          <img src={`${import.meta.env.BASE_URL}images/logo.svg`} alt="" aria-hidden="true" class="h-7 w-auto" />
          <p class="text-sm font-medium text-gray-700 dark:text-gray-300">Rakib Hasan</p>
        </div>
        <p class="text-xs text-gray-500 dark:text-gray-500 mt-0.5">
          Backend Software Developer & System Architect · Dhaka, Bangladesh
        </p>
      </div>

      <div class="flex items-center gap-6">
        {links.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-gray-500 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors"
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>

    <div class="mt-6 pt-6 border-t border-gray-100 dark:border-gray-800/50 text-center">
      <p class="text-xs text-gray-400 dark:text-gray-600">
        © {year} Rakib Hasan. Built with{' '}
        <a href="https://astro.build" class="hover:text-indigo-500 transition-colors">Astro</a>
        {' '}·{' '}
        <a href="https://tailwindcss.com" class="hover:text-indigo-500 transition-colors">Tailwind CSS</a>
        {' '}· Hosted on GitHub Pages.
      </p>
    </div>
  </div>
</footer>
