---
interface Props {
  levelPath: string;
  levelTitle: string;
  title: string;
  descriptionHtml: string;
  depth: number;
}

const { levelPath, levelTitle, title, descriptionHtml, depth } = Astro.props;

const depthColors = ['#6366f1', '#8b5cf6', '#06b6d4', '#9ca3af'];
const borderColor = depthColors[Math.min(depth, depthColors.length - 1)];
---

<div
  id={`step-${levelPath}`}
  class="scroll-mt-20 border-l-4 pl-5 mb-10"
  style={`border-color: ${borderColor}`}
>
  <div class="text-xs font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-1">
    {levelTitle}
  </div>

  <div class="flex items-center gap-3 mb-3">
    <span class="font-mono text-xs bg-indigo-50 dark:bg-indigo-950 text-indigo-600 dark:text-indigo-400 px-2 py-0.5 rounded border border-indigo-200 dark:border-indigo-800">
      {levelPath}
    </span>
    <h3 class="text-xl font-semibold text-gray-900 dark:text-white">{title}</h3>
  </div>

  <div class="prose prose-sm dark:prose-invert max-w-none" set:html={descriptionHtml} />
</div>
