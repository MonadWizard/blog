---
interface Step {
  levelPath: string;
  levelTitle: string;
  title: string;
  description: string;
}

interface TreeNode {
  step: Step;
  children: TreeNode[];
  levelPath: string;
}

interface LayoutNode {
  step: Step;
  levelPath: string;
  cx: number;
  cy: number;
  depth: number;
  children: LayoutNode[];
}

interface Edge {
  d: string;
}

interface Props {
  steps: Step[];
}

const { steps } = Astro.props;

// ── Tree builder ──────────────────────────────────────────────────────────────

function buildTree(steps: Step[]): TreeNode | null {
  if (!steps.length) return null;

  const nodeMap = new Map<string, TreeNode>();
  for (const step of steps) {
    nodeMap.set(step.levelPath, { step, children: [], levelPath: step.levelPath });
  }

  let root: TreeNode | null = null;
  for (const node of nodeMap.values()) {
    const parts = node.levelPath.split('.');
    const depth = parseInt(parts[0], 10);
    if (depth === 0) {
      root = node;
    } else {
      const parentDepth = depth - 1;
      const parentPath =
        parentDepth === 0 ? '0' : `${parentDepth}.${parts.slice(1, -1).join('.')}`;
      nodeMap.get(parentPath)?.children.push(node);
    }
  }

  function sortChildren(node: TreeNode) {
    node.children.sort((a, b) => {
      const ia = parseInt(a.levelPath.split('.').at(-1)!, 10);
      const ib = parseInt(b.levelPath.split('.').at(-1)!, 10);
      return ia - ib;
    });
    node.children.forEach(sortChildren);
  }
  if (root) sortChildren(root);
  return root;
}

// ── Layout constants ──────────────────────────────────────────────────────────

const NODE_W  = 200;
const NODE_H  = 72;
const LEVEL_GAP  = 120;   // center-to-center vertical distance between depths
const SIBLING_GAP = 20;   // horizontal gap between sibling subtrees
const PADDING = 48;

// Depth-based fill colors — vivid, high-contrast on any background.
// White text on all of them passes WCAG AA.
const DEPTH_COLORS = [
  '#0f172a',  // depth 0 — slate-900  (root, most prominent)
  '#4338ca',  // depth 1 — indigo-700
  '#7c3aed',  // depth 2 — violet-700
  '#0f766e',  // depth 3 — teal-700
  '#1d4ed8',  // depth 4 — blue-700
];
// Slightly lighter for dark mode (optional differentiation)
const DEPTH_COLORS_DARK = [
  '#1e293b',  // slate-800
  '#4f46e5',  // indigo-600
  '#8b5cf6',  // violet-500
  '#0d9488',  // teal-600
  '#2563eb',  // blue-600
];

function nodeColor(depth: number) {
  return DEPTH_COLORS[Math.min(depth, DEPTH_COLORS.length - 1)];
}
function nodeColorDark(depth: number) {
  return DEPTH_COLORS_DARK[Math.min(depth, DEPTH_COLORS_DARK.length - 1)];
}

// ── Layout algorithm ──────────────────────────────────────────────────────────

function subtreeWidth(node: TreeNode): number {
  if (!node.children.length) return NODE_W;
  const childWidths = node.children.map(subtreeWidth);
  return Math.max(
    NODE_W,
    childWidths.reduce((s, w) => s + w, 0) + (childWidths.length - 1) * SIBLING_GAP,
  );
}

function assignPositions(
  node: TreeNode,
  leftEdge: number,
  depth: number,
  allNodes: LayoutNode[],
): LayoutNode {
  const sw = subtreeWidth(node);
  const cx = leftEdge + sw / 2;
  const cy = PADDING + depth * LEVEL_GAP;

  const children: LayoutNode[] = [];
  let cursor = leftEdge;
  for (const child of node.children) {
    children.push(assignPositions(child, cursor, depth + 1, allNodes));
    cursor += subtreeWidth(child) + SIBLING_GAP;
  }

  const ln: LayoutNode = { step: node.step, levelPath: node.levelPath, cx, cy, depth, children };
  allNodes.push(ln);
  return ln;
}

// Smooth cubic bezier from bottom of parent to top of child
function collectEdges(node: LayoutNode, edges: Edge[]) {
  for (const child of node.children) {
    const x1 = node.cx;
    const y1 = node.cy + NODE_H / 2;
    const x2 = child.cx;
    const y2 = child.cy - NODE_H / 2;
    // Control points at mid-height for a clean S-curve
    const my = (y1 + y2) / 2;
    edges.push({ d: `M ${x1},${y1} C ${x1},${my} ${x2},${my} ${x2},${y2}` });
    collectEdges(child, edges);
  }
}

// ── Run layout ────────────────────────────────────────────────────────────────

const root = buildTree(steps);
let nodes: LayoutNode[] = [];
let edges: Edge[] = [];
let svgWidth  = NODE_W + PADDING * 2;
let svgHeight = NODE_H + PADDING * 2;

let layoutRoot: LayoutNode | null = null;
if (root) {
  layoutRoot = assignPositions(root, PADDING, 0, nodes);
  collectEdges(layoutRoot, edges);
  svgWidth  = Math.max(...nodes.map((n) => n.cx + NODE_W / 2)) + PADDING;
  svgHeight = Math.max(...nodes.map((n) => n.cy)) + NODE_H / 2 + PADDING;
}

const darkModeNodeStyles = nodes.map((n) =>
  `html.dark #rm-rect-${n.levelPath.replace(/\./g, '-')} { fill: ${nodeColorDark(n.depth)}; }`
).join('\n        ');

function trunc(text: string, maxLen: number) {
  return text.length > maxLen ? text.slice(0, maxLen - 1) + '…' : text;
}
---

{root ? (
  <div class="overflow-x-auto rounded-xl">
    <svg
      viewBox={`0 0 ${svgWidth} ${svgHeight}`}
      width={svgWidth}
      height={svgHeight}
      style="max-width: 100%;"
      xmlns="http://www.w3.org/2000/svg"
      aria-label="Journey roadmap tree"
    >
      <style>{`
        .rm-edge {
          fill: none;
          stroke: #94a3b8;
          stroke-width: 2;
          stroke-linecap: round;
        }
        html.dark .rm-edge { stroke: #475569; }

        .rm-link { cursor: pointer; }
        .rm-link:hover .rm-rect { filter: brightness(1.25); }
        .rm-link:focus-visible .rm-rect { outline: 3px solid #fbbf24; outline-offset: 2px; }

        .rm-level {
          font-size: 9px;
          font-family: ui-sans-serif, system-ui, sans-serif;
          font-weight: 800;
          letter-spacing: 0.10em;
          text-transform: uppercase;
          fill: #fde047;
        }
        .rm-title {
          font-size: 12px;
          font-family: ui-sans-serif, system-ui, sans-serif;
          font-weight: 700;
          fill: #ffffff;
        }

        ${darkModeNodeStyles}
      `}</style>

      <defs>
        <marker id="rm-arrow" markerWidth="8" markerHeight="8" refX="7" refY="4" orient="auto">
          <path d="M1,1 L7,4 L1,7 Z" fill="#94a3b8" />
        </marker>
        <marker id="rm-arrow-dark" markerWidth="8" markerHeight="8" refX="7" refY="4" orient="auto">
          <path d="M1,1 L7,4 L1,7 Z" fill="#475569" />
        </marker>
      </defs>

      <!-- Edges (rendered first, behind nodes) -->
      {edges.map((edge) => (
        <path
          d={edge.d}
          class="rm-edge"
          marker-end="url(#rm-arrow)"
        />
      ))}

      <!-- Nodes -->
      {nodes.map((node) => {
        const safeId = node.levelPath.replace(/\./g, '-');
        const x = node.cx - NODE_W / 2;
        const y = node.cy - NODE_H / 2;
        return (
          <a
            href={`#step-${node.levelPath}`}
            class="rm-link"
            aria-label={`${node.step.levelTitle}: ${node.step.title}`}
          >
            {/* Colored filled rectangle */}
            <rect
              id={`rm-rect-${safeId}`}
              x={x}
              y={y}
              width={NODE_W}
              height={NODE_H}
              rx="10"
              fill={nodeColor(node.depth)}
              class="rm-rect"
            />

            {/* Depth 0 (root) gets a top accent bar */}
            {node.depth === 0 && (
              <rect
                x={x + 16}
                y={y + NODE_H - 5}
                width={NODE_W - 32}
                height={4}
                rx="2"
                fill="rgba(255,255,255,0.25)"
              />
            )}

            {/* Category / level title */}
            <text
              x={node.cx}
              y={node.cy - 10}
              text-anchor="middle"
              class="rm-level"
            >
              {trunc(node.step.levelTitle.toUpperCase(), 28)}
            </text>

            {/* Main step title */}
            <text
              x={node.cx}
              y={node.cy + 10}
              text-anchor="middle"
              class="rm-title"
            >
              {trunc(node.step.title, 24)}
            </text>
          </a>
        );
      })}
    </svg>
  </div>
) : (
  <p class="text-gray-400 italic text-sm">No steps defined for this journey yet.</p>
)}
