---
import JourneyTreeNode from './JourneyTreeNode.astro';

type Marker = 'strength' | 'mock' | 'gate';

interface Step {
  levelPath: string;
  levelTitle: string;
  title: string;
  description: string;
  markers?: Marker[];
}

const MARKER_EMOJI: Record<Marker, string> = { strength: '⭐', mock: '🎯', gate: '🔑' };

interface TreeNode {
  step: Step;
  children: TreeNode[];
  levelPath: string;
}

interface TextLine {
  text: string;
  relY: number;
  cls: 'rm-level' | 'rm-title';
}

interface Measurement {
  width: number;
  height: number;
  lines: TextLine[];
}

interface LayoutNode {
  step: Step;
  levelPath: string;
  cx: number;
  cy: number;
  depth: number;
  width: number;
  height: number;
  lines: TextLine[];
  children: LayoutNode[];
}

interface Edge {
  d: string;
}

interface Props {
  steps: Step[];
}

const { steps } = Astro.props;

// ── Tree builder ──────────────────────────────────────────────────────────────

function buildTree(steps: Step[]): TreeNode | null {
  if (!steps.length) return null;

  const nodeMap = new Map<string, TreeNode>();
  for (const step of steps) {
    nodeMap.set(step.levelPath, { step, children: [], levelPath: step.levelPath });
  }

  let root: TreeNode | null = null;
  for (const node of nodeMap.values()) {
    const parts = node.levelPath.split('.');
    const depth = parseInt(parts[0], 10);
    if (depth === 0) {
      root = node;
    } else {
      const parentDepth = depth - 1;
      const parentPath =
        parentDepth === 0 ? '0' : `${parentDepth}.${parts.slice(1, -1).join('.')}`;
      nodeMap.get(parentPath)?.children.push(node);
    }
  }

  function sortChildren(node: TreeNode) {
    node.children.sort((a, b) => {
      const ia = parseInt(a.levelPath.split('.').at(-1)!, 10);
      const ib = parseInt(b.levelPath.split('.').at(-1)!, 10);
      return ia - ib;
    });
    node.children.forEach(sortChildren);
  }
  if (root) sortChildren(root);
  return root;
}

// ── Layout constants ──────────────────────────────────────────────────────────

const MIN_NODE_W = 150;
const MAX_NODE_W = 240;
const MIN_NODE_H = 64;
const PAD_X = 16;
const PAD_Y = 14;

const LEVEL_FONT = 9;
const LEVEL_CHAR_FACTOR = 0.68; // uppercase, heavier weight glyphs are wider
const LEVEL_LETTER_SPACING_EM = 0.10;
const LEVEL_LINE_H = 12;
const MAX_LEVEL_LINES = 1;

const TITLE_FONT = 12;
const TITLE_CHAR_FACTOR = 0.58; // mixed-case bold
const TITLE_LINE_H = 16;
const MAX_TITLE_LINES = 2;

const BLOCK_GAP = 6;      // gap between level label and title text
const SIBLING_GAP = 20;   // horizontal gap between sibling subtrees
const VERTICAL_GAP = 56;  // vertical gap between rows of boxes
const PADDING = 48;

// Depth-based fill colors — vivid, high-contrast on any background.
const DEPTH_COLORS = [
  '#0f172a',  // depth 0 — slate-900  (root, most prominent)
  '#4338ca',  // depth 1 — indigo-700
  '#7c3aed',  // depth 2 — violet-700
  '#0f766e',  // depth 3 — teal-700
  '#1d4ed8',  // depth 4 — blue-700
];
// Lighter tints for dark mode so boxes stay highlighted against a dark background.
const DEPTH_COLORS_DARK = [
  '#cbd5e1',  // slate-300 — root
  '#a5b4fc',  // indigo-300
  '#c4b5fd',  // violet-300
  '#5eead4',  // teal-300
  '#93c5fd',  // blue-300
];

function nodeColor(depth: number) {
  return DEPTH_COLORS[Math.min(depth, DEPTH_COLORS.length - 1)];
}
function nodeColorDark(depth: number) {
  return DEPTH_COLORS_DARK[Math.min(depth, DEPTH_COLORS_DARK.length - 1)];
}

// ── Text measurement & wrapping (estimated — no DOM available at build time) ───

function estimateTextWidth(text: string, fontSize: number, charFactor: number, letterSpacingEm = 0): number {
  return text.length * (fontSize * charFactor + fontSize * letterSpacingEm);
}

// Greedy word-wrap bounded by maxLines; ellipsizes whatever doesn't fit,
// and hard-truncates any single line (even a lone long word) that still overflows maxWidth.
function wrapText(
  text: string,
  fontSize: number,
  charFactor: number,
  maxWidth: number,
  maxLines: number,
  letterSpacingEm = 0,
): string[] {
  const width = (s: string) => estimateTextWidth(s, fontSize, charFactor, letterSpacingEm);
  const words = text.replace(/\s+/g, ' ').trim().split(' ').filter(Boolean);
  if (!words.length) return [''];

  const lines: string[] = [];
  let current = '';
  let wordIndex = 0;

  while (wordIndex < words.length && lines.length < maxLines) {
    const word = words[wordIndex];
    const candidate = current ? `${current} ${word}` : word;
    if (!current || width(candidate) <= maxWidth) {
      current = candidate;
      wordIndex++;
    } else {
      lines.push(current);
      current = '';
    }
  }
  if (current) lines.push(current);

  const truncatedByLineLimit = wordIndex < words.length;

  return lines.map((line, idx) => {
    const isLast = idx === lines.length - 1;
    const needsEllipsis = isLast && truncatedByLineLimit;
    if (width(line) <= maxWidth && !needsEllipsis) return line;
    let shortened = line;
    while (shortened.length > 1 && width(shortened + '…') > maxWidth) {
      shortened = shortened.slice(0, -1);
    }
    return shortened.replace(/[.,;:\s]+$/, '') + '…';
  });
}

function measureNode(step: Step): Measurement {
  const maxTextWidth = MAX_NODE_W - PAD_X * 2;
  const levelText = step.levelTitle.toUpperCase();
  const levelLines = wrapText(levelText, LEVEL_FONT, LEVEL_CHAR_FACTOR, maxTextWidth, MAX_LEVEL_LINES, LEVEL_LETTER_SPACING_EM);
  const titleLines = wrapText(step.title, TITLE_FONT, TITLE_CHAR_FACTOR, maxTextWidth, MAX_TITLE_LINES);

  const widest = Math.max(
    ...levelLines.map((l) => estimateTextWidth(l, LEVEL_FONT, LEVEL_CHAR_FACTOR, LEVEL_LETTER_SPACING_EM)),
    ...titleLines.map((l) => estimateTextWidth(l, TITLE_FONT, TITLE_CHAR_FACTOR)),
  );
  // Small safety margin on top of the estimate — better to size slightly too wide than to clip.
  const width = Math.min(MAX_NODE_W, Math.max(MIN_NODE_W, Math.ceil(widest * 1.08) + PAD_X * 2));

  const textBlockHeight = levelLines.length * LEVEL_LINE_H + BLOCK_GAP + titleLines.length * TITLE_LINE_H;
  const height = Math.max(MIN_NODE_H, Math.ceil(textBlockHeight + PAD_Y * 2));

  const lines: TextLine[] = [];
  let pos = -textBlockHeight / 2;
  for (const line of levelLines) {
    lines.push({ text: line, relY: pos + LEVEL_LINE_H * 0.78, cls: 'rm-level' });
    pos += LEVEL_LINE_H;
  }
  pos += BLOCK_GAP;
  for (const line of titleLines) {
    lines.push({ text: line, relY: pos + TITLE_LINE_H * 0.78, cls: 'rm-title' });
    pos += TITLE_LINE_H;
  }

  return { width, height, lines };
}

// ── Layout algorithm ──────────────────────────────────────────────────────────

function subtreeWidth(node: TreeNode, measurements: Map<string, Measurement>): number {
  const w = measurements.get(node.levelPath)!.width;
  if (!node.children.length) return w;
  const childWidths = node.children.map((c) => subtreeWidth(c, measurements));
  return Math.max(
    w,
    childWidths.reduce((s, cw) => s + cw, 0) + (childWidths.length - 1) * SIBLING_GAP,
  );
}

function computeMeasurements(
  node: TreeNode,
  depth: number,
  measurements: Map<string, Measurement>,
  depthHeights: number[],
) {
  const m = measureNode(node.step);
  measurements.set(node.levelPath, m);
  depthHeights[depth] = Math.max(depthHeights[depth] ?? 0, m.height);
  for (const child of node.children) computeMeasurements(child, depth + 1, measurements, depthHeights);
}

// Vertical center for each depth row, stacked by each row's tallest box.
function computeRowCenters(depthHeights: number[]): number[] {
  const centers: number[] = [];
  let cursorY = PADDING;
  for (let d = 0; d < depthHeights.length; d++) {
    const h = depthHeights[d];
    centers[d] = cursorY + h / 2;
    cursorY += h + VERTICAL_GAP;
  }
  return centers;
}

function assignPositions(
  node: TreeNode,
  leftEdge: number,
  depth: number,
  allNodes: LayoutNode[],
  measurements: Map<string, Measurement>,
  rowCenters: number[],
): LayoutNode {
  const sw = subtreeWidth(node, measurements);
  const cx = leftEdge + sw / 2;
  const cy = rowCenters[depth];
  const m = measurements.get(node.levelPath)!;

  const children: LayoutNode[] = [];
  let cursor = leftEdge;
  for (const child of node.children) {
    children.push(assignPositions(child, cursor, depth + 1, allNodes, measurements, rowCenters));
    cursor += subtreeWidth(child, measurements) + SIBLING_GAP;
  }

  const ln: LayoutNode = {
    step: node.step,
    levelPath: node.levelPath,
    cx,
    cy,
    depth,
    width: m.width,
    height: m.height,
    lines: m.lines,
    children,
  };
  allNodes.push(ln);
  return ln;
}

// Smooth cubic bezier from bottom of parent to top of child
function collectEdges(node: LayoutNode, edges: Edge[]) {
  for (const child of node.children) {
    const x1 = node.cx;
    const y1 = node.cy + node.height / 2;
    const x2 = child.cx;
    const y2 = child.cy - child.height / 2;
    // Control points at mid-height for a clean S-curve
    const my = (y1 + y2) / 2;
    edges.push({ d: `M ${x1},${y1} C ${x1},${my} ${x2},${my} ${x2},${y2}` });
    collectEdges(child, edges);
  }
}

// ── Run layout ────────────────────────────────────────────────────────────────

const root = buildTree(steps);
let nodes: LayoutNode[] = [];
let edges: Edge[] = [];
let svgWidth  = PADDING * 2;
let svgHeight = PADDING * 2;

let layoutRoot: LayoutNode | null = null;
if (root) {
  const measurements = new Map<string, Measurement>();
  const depthHeights: number[] = [];
  computeMeasurements(root, 0, measurements, depthHeights);
  const rowCenters = computeRowCenters(depthHeights);

  layoutRoot = assignPositions(root, PADDING, 0, nodes, measurements, rowCenters);
  collectEdges(layoutRoot, edges);
  svgWidth  = Math.max(...nodes.map((n) => n.cx + n.width / 2)) + PADDING;
  svgHeight = Math.max(...nodes.map((n) => n.cy + n.height / 2)) + PADDING;
}

// Every depth is drawn on one shared horizontal row (org-chart layout), so a tree with a
// very wide fanout at some depth (e.g. hundreds of leaf siblings across many branches)
// produces an SVG too wide to be usable even with horizontal scroll. Past this width, skip
// the SVG entirely and use the recursive stacked view (JourneyTreeNode) on all breakpoints.
const SVG_MAX_WIDTH = 6000;
const useSvg = root !== null && svgWidth <= SVG_MAX_WIDTH;

---

{root ? (
  <>
  {/* Below `lg`, boxes rearrange into a vertical stack (JourneyTreeNode) instead
      of shrinking — this SVG tree keeps its true pixel size (never scaled down,
      so text never shrinks) and only scrolls horizontally if it overflows. */}
  {useSvg && (
  <div class="hidden overflow-x-auto rounded-xl lg:block">
    <svg
      viewBox={`0 0 ${svgWidth} ${svgHeight}`}
      width={svgWidth}
      height={svgHeight}
      style="display: block; margin: 0 auto;"
      xmlns="http://www.w3.org/2000/svg"
      aria-label="Journey roadmap tree"
    >
      <style>
        .rm-edge {
          fill: none;
          stroke: #94a3b8;
          stroke-width: 2;
          stroke-linecap: round;
        }
        html.dark .rm-edge { stroke: #475569; }

        .rm-link { cursor: pointer; }
        .rm-link:hover .rm-rect { filter: brightness(1.2); }
        .rm-link:focus-visible .rm-rect { outline: 3px solid #fbbf24; outline-offset: 2px; }

        /* Each node sets --fill-light/--fill-dark inline (per-depth color);
           these rules just pick the right one for the active theme. */
        .rm-rect {
          fill: var(--fill-light);
          stroke: none;
          transition: filter 0.15s ease;
        }
        html.dark .rm-rect {
          fill: var(--fill-dark);
        }

        /* Text color is the reverse of the box fill, so it always reads
           clearly on top of the solid colored background. */
        .rm-level, .rm-title {
          fill: #ffffff;
        }
        html.dark .rm-level, html.dark .rm-title {
          fill: #0f172a;
        }

        .rm-accent {
          fill: #ffffff;
          opacity: 0.22;
        }
        html.dark .rm-accent {
          fill: #0f172a;
          opacity: 0.28;
        }

        .rm-level {
          font-size: 9px;
          font-family: ui-sans-serif, system-ui, sans-serif;
          font-weight: 800;
          letter-spacing: 0.10em;
          text-transform: uppercase;
        }
        .rm-title {
          font-size: 12px;
          font-family: ui-sans-serif, system-ui, sans-serif;
          font-weight: 700;
        }
        .rm-marker {
          font-size: 12px;
        }
      </style>

      <defs>
        <marker id="rm-arrow" markerWidth="8" markerHeight="8" refX="7" refY="4" orient="auto">
          <path d="M1,1 L7,4 L1,7 Z" fill="#94a3b8" />
        </marker>
        <marker id="rm-arrow-dark" markerWidth="8" markerHeight="8" refX="7" refY="4" orient="auto">
          <path d="M1,1 L7,4 L1,7 Z" fill="#475569" />
        </marker>
      </defs>

      <!-- Edges (rendered first, behind nodes) -->
      {edges.map((edge) => (
        <path
          d={edge.d}
          class="rm-edge"
          marker-end="url(#rm-arrow)"
        />
      ))}

      <!-- Nodes -->
      {nodes.map((node) => {
        const safeId = node.levelPath.replace(/\./g, '-');
        const x = node.cx - node.width / 2;
        const y = node.cy - node.height / 2;
        return (
          <a
            href={`#step-${node.levelPath}`}
            class="rm-link"
            aria-label={`${node.step.levelTitle}: ${node.step.title}`}
          >
            {/* Solid, colored background — text below is the reverse (contrast) color.
                Both theme colors are passed in as CSS vars since inline fill can't
                react to the html.dark class the way a stylesheet rule can. */}
            <rect
              id={`rm-rect-${safeId}`}
              x={x}
              y={y}
              width={node.width}
              height={node.height}
              rx="10"
              class="rm-rect"
              style={`--fill-light: ${nodeColor(node.depth)}; --fill-dark: ${nodeColorDark(node.depth)};`}
            />

            {/* Depth 0 (root) gets a bottom accent bar */}
            {node.depth === 0 && (
              <rect
                x={x + 16}
                y={y + node.height - 5}
                width={node.width - 32}
                height={4}
                rx="2"
                class="rm-accent"
              />
            )}

            {/* Marker badge (strength / mock / gate) in the top-right corner */}
            {(node.step.markers?.length ?? 0) > 0 && (
              <text
                x={x + node.width - 8}
                y={y + 15}
                text-anchor="end"
                class="rm-marker"
              >
                {node.step.markers!.map((m) => MARKER_EMOJI[m]).join('')}
              </text>
            )}

            {/* Category / level title + main step title, each wrapped and
                centered to fit fully inside the box */}
            {node.lines.map((line) => (
              <text
                x={node.cx}
                y={node.cy + line.relY}
                text-anchor="middle"
                class={line.cls}
              >
                {line.text}
              </text>
            ))}
          </a>
        );
      })}
    </svg>
  </div>
  )}

  <ul class={useSvg ? 'lg:hidden' : ''}>
    <JourneyTreeNode node={root} depth={0} />
  </ul>
  </>
) : (
  <p class="text-gray-400 italic text-sm">No steps defined for this journey yet.</p>
)}
