---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const skills = [
  {
    category: 'Languages & Frameworks',
    items: ['Python', 'Django', 'FastAPI', 'Django REST Framework', 'REST APIs', 'GraphQL'],
  },
  {
    category: 'Databases & Search',
    items: ['PostgreSQL', 'Redis', 'Elasticsearch', 'SQLite', 'Elasticsearch DBA'],
  },
  {
    category: 'Infrastructure & DevOps',
    items: ['Nginx', 'Docker', 'Linux', 'GitHub Actions', 'CI/CD', 'Server Security'],
  },
  {
    category: 'Architecture Patterns',
    items: ['Microservices', 'Event-Driven', 'Data Pipelines', 'Caching Strategies', 'Full-Text Search'],
  },
];

const experience = [
  {
    role: 'Backend Software Developer & System Architect',
    company: 'Freelance / Open Source',
    period: '2022 — Present',
    description: 'Designing and building highly scalable RESTful services and robust backend infrastructure. Core stack: Django, FastAPI, Python. Architecting complex data pipelines connecting PostgreSQL, Redis, and Elasticsearch.',
  },
];
---

<BaseLayout
  title="About — Rakib Hasan"
  description="Backend Software Developer & System Architect based in Dhaka, Bangladesh. Specializing in Django, FastAPI, PostgreSQL, Redis, and Elasticsearch."
>
  <Navbar />

  <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">

    <!-- Profile section -->
    <section class="mb-16 pb-16 border-b border-gray-100 dark:border-gray-800">
      <div class="flex flex-col sm:flex-row gap-8 items-start">
        <!-- Avatar placeholder -->
        <div class="flex-shrink-0 w-24 h-24 rounded-full bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center text-white text-3xl font-bold select-none">
          R
        </div>

        <div class="flex-1">
          <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-1">Rakib Hasan</h1>
          <p class="text-indigo-600 dark:text-indigo-400 font-medium mb-1">Backend Software Developer & System Architect</p>
          <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">
            <svg class="inline w-4 h-4 mr-1 -mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
            </svg>
            Dhaka, Bangladesh
          </p>
          <p class="text-gray-600 dark:text-gray-300 leading-relaxed max-w-2xl">
            I specialize in building highly scalable RESTful services and robust backend infrastructure.
            My core stack includes <strong class="text-gray-800 dark:text-gray-200">Django, FastAPI, and Python</strong>.
            I design complex data pipelines connecting <strong class="text-gray-800 dark:text-gray-200">PostgreSQL, Redis, and Elasticsearch</strong>,
            and I am currently advancing my expertise in Elasticsearch Database Administration (DBA).
            I am meticulous about server security, specifically configuring
            <strong class="text-gray-800 dark:text-gray-200">Nginx deployments</strong> to strictly serve assigned domains
            and reject catch-all traffic.
          </p>

          <!-- Resume download -->
          <div class="mt-6 flex flex-wrap gap-3">
            <a
              href={`${import.meta.env.BASE_URL}resume.pdf`}
              download
              class="inline-flex items-center gap-2 px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium rounded-lg transition-colors"
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
              </svg>
              Download Resume
            </a>
            <a
              href="https://github.com/MonadWizard"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2 bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300 text-sm font-medium rounded-lg transition-colors"
            >
              GitHub
            </a>
            <a
              href="https://www.linkedin.com/in/rakib-hasan-90518b140/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2 bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300 text-sm font-medium rounded-lg transition-colors"
            >
              LinkedIn
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Skills -->
    <section class="mb-16">
      <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-8">Technical Skills</h2>
      <div class="grid sm:grid-cols-2 gap-8">
        {skills.map((group) => (
          <div>
            <h3 class="text-xs font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-3">
              {group.category}
            </h3>
            <div class="flex flex-wrap gap-2">
              {group.items.map((skill) => (
                <span class="inline-flex items-center px-3 py-1 bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 text-sm font-medium rounded-full border border-gray-200 dark:border-gray-700 hover:border-indigo-400 dark:hover:border-indigo-500 transition-colors">
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Experience -->
    <section class="mb-16">
      <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-8">Experience</h2>
      <div class="space-y-8">
        {experience.map((job) => (
          <div class="flex gap-4">
            <div class="flex-shrink-0 mt-1 w-2 h-2 rounded-full bg-indigo-500 ring-4 ring-indigo-100 dark:ring-indigo-900/40"></div>
            <div>
              <h3 class="font-semibold text-gray-900 dark:text-white">{job.role}</h3>
              <p class="text-sm text-indigo-600 dark:text-indigo-400 font-medium">{job.company}</p>
              <p class="text-xs text-gray-400 dark:text-gray-500 mb-2">{job.period}</p>
              <p class="text-gray-600 dark:text-gray-300 text-sm leading-relaxed">{job.description}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Workspace -->
    <section>
      <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-6">Workspace</h2>
      <div class="p-6 bg-gray-50 dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-700">
        <div class="grid sm:grid-cols-2 gap-4 text-sm">
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-1">GPU</p>
            <p class="text-gray-700 dark:text-gray-300 font-medium">Intel Arc A770</p>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-1">CPU</p>
            <p class="text-gray-700 dark:text-gray-300 font-medium">AMD Ryzen 7 7700</p>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-1">OS</p>
            <p class="text-gray-700 dark:text-gray-300 font-medium">Linux</p>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-1">Editor</p>
            <p class="text-gray-700 dark:text-gray-300 font-medium">VS Code + Claude Code</p>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>
