---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';
import rakibPhoto from '../assets/rakib.jpg';
import readingTime from 'reading-time';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---

<BaseLayout
  title="Rakib Hasan — Backend Software Developer & System Architect"
  description="Writing about Django, FastAPI, PostgreSQL, Redis, Elasticsearch, Nginx, and scalable backend systems."
>
  <Navbar />

  <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Hero -->
    <section class="py-16 border-b border-gray-100 dark:border-gray-800">
      <div class="flex flex-col md:flex-row md:items-center gap-10">
        <div class="max-w-2xl">
          <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-gray-900 dark:text-white mb-5 leading-tight">
            Hi, I'm Rakib Hasan
          </h1>
          <p class="text-lg text-gray-600 dark:text-gray-300 leading-relaxed mb-6">
            Backend Software Developer & System Architect based in
            <span class="font-medium text-gray-800 dark:text-gray-200">Dhaka, Bangladesh</span>.
            I build highly scalable RESTful services and backend infrastructure using
            <span class="font-medium text-gray-800 dark:text-gray-200">Django, FastAPI, and Python</span>.
            I design data pipelines with PostgreSQL, Redis, and Elasticsearch, and obsess over
            Nginx security configuration. I care about clean architecture, fast queries, and
            servers that stay up — and I write about what I learn along the way.
          </p>
          <div class="flex flex-wrap gap-3">
            <a
              href={`${import.meta.env.BASE_URL}about`}
              class="inline-flex items-center gap-2 px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium rounded-lg transition-colors"
            >
              About me
            </a>
            <a
              href="https://github.com/MonadWizard"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2 bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-300 text-sm font-medium rounded-lg transition-colors"
            >
              GitHub
            </a>
          </div>
        </div>
        <div class="flex-shrink-0 mx-auto md:mx-0">
          <div class="photo-frame w-56 sm:w-64">
            <Image
              src={rakibPhoto}
              alt="Rakib Hasan"
              width={560}
              height={747}
              class="w-full h-auto"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- What I work on -->
    <section class="py-12 border-b border-gray-100 dark:border-gray-800">
      <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-2">
        What I Work On
      </h2>
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-6">
        The kind of problems I enjoy solving.
      </p>
      <div class="grid sm:grid-cols-3 gap-4">
        <div class="p-6 bg-gray-50 dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-700">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2">Scalable APIs & Services</h3>
          <p class="text-gray-600 dark:text-gray-300 text-sm leading-relaxed">
            Highly scalable RESTful services with Django, FastAPI, and Python — clean,
            well-documented, and built to handle load.
          </p>
        </div>
        <div class="p-6 bg-gray-50 dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-700">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2">Data Pipelines & Search</h3>
          <p class="text-gray-600 dark:text-gray-300 text-sm leading-relaxed">
            Pipelines connecting PostgreSQL, Redis, and Elasticsearch — full-text search,
            caching strategies, and fast queries at scale.
          </p>
        </div>
        <div class="p-6 bg-gray-50 dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-700">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2">Infrastructure & Security</h3>
          <p class="text-gray-600 dark:text-gray-300 text-sm leading-relaxed">
            Hardened Nginx, Docker, Linux, and CI/CD — servers that strictly serve their
            domains and reject catch-all traffic.
          </p>
        </div>
      </div>
    </section>

    <!-- Motivation -->
    <section class="py-12 border-b border-gray-100 dark:border-gray-800">
      <blockquote class="border-l-4 border-indigo-500 pl-6 italic text-xl sm:text-2xl leading-relaxed text-gray-700 dark:text-gray-300">
        Code is craft. Every system I ship is a promise it'll still be standing —
        fast, secure, and scalable — long after the last commit. Build things that last,
        learn relentlessly, and leave the codebase better than you found it.
      </blockquote>
    </section>

    <!-- Posts feed -->
    <section class="py-8">
      <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-2">
        Latest Articles
      </h2>
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-6">
        {posts.length} {posts.length === 1 ? 'article' : 'articles'} on backend engineering, system design, and infrastructure.
      </p>

      {posts.length === 0 && (
        <p class="text-gray-400 dark:text-gray-500 py-12 text-center">No posts yet. Check back soon.</p>
      )}

      {posts.map((post) => {
        const rt = readingTime(post.body ?? '');
        return (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            slug={post.id}
            heroImage={post.data.heroImage}
            readingTime={rt.text}
          />
        );
      })}
    </section>
  </main>

  <Footer />
</BaseLayout>
